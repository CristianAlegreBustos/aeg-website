---
// Contact.astro
---
<section id="contacto" class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-extrabold text-blue-950 tracking-tight mb-4">
        Impulsemos tu próximo proyecto
      </h2>
      <p class="text-lg text-slate-600">
        Contanos qué desafío tecnológico enfrenta tu empresa. Te contactaremos a la brevedad para diseñar una solución a medida.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      
      <!-- Contact Info -->
      <div class="space-y-8 lg:pr-8">
        <div class="bg-blue-50/50 rounded-2xl p-8 border border-blue-100">
          <h3 class="text-xl font-bold text-slate-900 mb-6">Información Directa</h3>
          <ul class="space-y-6">
            <li class="flex items-start gap-4">
              <div class="bg-blue-100 p-3 rounded-lg text-blue-700">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.2 8.4c.5.38.8.97.8 1.6v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V10a2 2 0 0 1 .8-1.6l8-6a2 2 0 0 1 2.4 0l8 6Z"/><path d="m22 10-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 10"/></svg>
              </div>
              <div>
                <strong class="block text-slate-900 font-semibold mb-1">Email</strong>
                <a href="mailto:cristian.alegre.it@gmail.com" class="text-blue-700 hover:text-blue-800 transition-colors font-medium">cristian.alegre.it@gmail.com</a>
              </div>
            </li>
            <li class="flex items-start gap-4">
              <div class="bg-blue-100 p-3 rounded-lg text-blue-700">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div>
                <strong class="block text-slate-900 font-semibold mb-1">Ubicación</strong>
                <span class="text-slate-600 block">Santa Fe, Argentina</span>
                <span class="text-sm text-slate-500 font-medium">(Atención global a equipos remotos)</span>
              </div>
            </li>
            <li class="flex items-start gap-4">
              <div class="bg-blue-100 p-3 rounded-lg text-blue-700">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
              </div>
              <div>
                <strong class="block text-slate-900 font-semibold mb-1">LinkedIn</strong>
                <a href="https://www.linkedin.com/in/cristian-nahuel-alegre-bustos/" target="_blank" rel="noopener noreferrer" class="text-blue-700 hover:text-blue-800 transition-colors font-medium">Cristian Nahuel Alegre Bustos</a>
              </div>
            </li>
          </ul>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="bg-white rounded-2xl shadow-xl border border-slate-100 p-8">
        <form id="contact-form" action="#" method="POST" class="space-y-6">
          


          <div>
            <label for="name" class="block text-sm font-semibold text-slate-900 mb-2">Nombre completo</label>
            <input type="text" name="name" id="name" class="block w-full rounded-lg border-0 px-4 py-3 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm sm:leading-6 transition-all" placeholder="Ej. Juan Pérez" required minlength="2" maxlength="100">
          </div>

          <div>
            <label for="email" class="block text-sm font-semibold text-slate-900 mb-2">Email corporativo</label>
            <input type="email" name="email" id="email" class="block w-full rounded-lg border-0 px-4 py-3 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm sm:leading-6 transition-all" placeholder="juan@tuempresa.com" required maxlength="150" pattern="[a-z0-9._%+-]+@[a-z0-9.-]+\\.[a-z]{2,}$">
          </div>

          <div>
            <label for="company" class="block text-sm font-semibold text-slate-900 mb-2">Empresa / Proyecto</label>
            <input type="text" name="company" id="company" class="block w-full rounded-lg border-0 px-4 py-3 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm sm:leading-6 transition-all" placeholder="Nombre de tu empresa" maxlength="150">
          </div>

          <div>
            <label for="message" class="block text-sm font-semibold text-slate-900 mb-2">¿En qué podemos ayudarte?</label>
            <textarea id="message" name="message" rows="4" class="block w-full rounded-lg border-0 px-4 py-3 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm sm:leading-6 transition-all resize-none" placeholder="Contanos brevemente sobre tu desafío tecnológico..." required minlength="10" maxlength="1000"></textarea>
          </div>

          <!-- Honeypot oculto -->
          <input type="checkbox" name="botcheck" class="hidden" style="display: none;" />

          <button id="submit-btn" type="submit" class="w-full inline-flex justify-center items-center rounded-lg bg-blue-900 px-8 py-4 text-sm font-semibold text-white shadow-sm hover:bg-blue-800 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 transition-all duration-200 disabled:opacity-70 disabled:cursor-not-allowed">
            <span id="btn-text">Solicitar consultoría técnica</span>
            <svg id="btn-spinner" class="animate-spin ml-2 h-5 w-5 text-white hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
          </button>
          
          <div id="form-status" class="hidden mt-4 text-sm font-medium"></div>
        </form>
      </div>
      
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText = document.getElementById('btn-text');
  const btnSpinner = document.getElementById('btn-spinner');
  const formStatus = document.getElementById('form-status');

  const WEBHOOK_URL = 'https://hook.us2.make.com/uiuxuvwqvt44m2fxbnl9jrfpqqb3dnqa';

  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const formData = new FormData(form);
      const botcheck = formData.get('botcheck');
      
      if (botcheck) {
        return; // Detener silenciosamente si el botcheck está marcado
      }

      // Deshabilitar botón y cambiar texto
      submitBtn.disabled = true;
      const originalText = btnText ? btnText.textContent : 'Solicitar consultoría técnica';
      if (btnText) btnText.textContent = 'Enviando...';
      if (btnSpinner) btnSpinner.classList.remove('hidden');
      
      // Ocultar mensaje previo
      if (formStatus) formStatus.className = 'hidden mt-4 text-sm font-medium';

      // Convertir FormData a JSON
      const data = Object.fromEntries(formData.entries());
      delete data.botcheck; // Quitamos el botcheck del payload

      fetch(WEBHOOK_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      })
      .then(response => {
        if (!response.ok) throw new Error('Network response was not ok');
        
        // Éxito
        if (formStatus) {
          formStatus.textContent = '¡Mensaje enviado con éxito! Nos contactaremos a la brevedad.';
          formStatus.className = 'mt-4 text-sm font-medium text-center p-4 rounded-lg bg-green-50 text-green-800 border border-green-200 block';
        }
        form.reset();
      })
      .catch(error => {
        // Error
        console.error('Error:', error);
        if (formStatus) {
          formStatus.textContent = 'Hubo un error al enviar el mensaje. Por favor, intenta de nuevo.';
          formStatus.className = 'mt-4 text-sm font-medium text-center p-4 rounded-lg bg-red-50 text-red-800 border border-red-200 block';
        }
      })
      .finally(() => {
        // Restaurar estado del botón
        submitBtn.disabled = false;
        if (btnText) btnText.textContent = originalText;
        if (btnSpinner) btnSpinner.classList.add('hidden');
      });
    });
  }
</script>
