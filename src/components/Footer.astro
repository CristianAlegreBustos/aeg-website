---
// Footer.astro
---

<footer
  class="bg-slate-900 border-t border-slate-800 pt-16 pb-8 text-slate-300"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 lg:gap-8 mb-16">
      <!-- Columna 1: Marca y Misión -->
      <div class="md:col-span-5 lg:col-span-4">
        <a
          href="#"
          class="inline-block text-2xl font-black text-white tracking-tighter mb-6"
        >
          AEG<span class="text-blue-500">.</span>
        </a>
        <p class="text-slate-400 leading-relaxed max-w-sm">
          Ingeniería de software y automatización diseñada para que tu negocio
          escale <b>y tu vida tambien.</b>
        </p>
      </div>

      <!-- Columna 2: Enlaces Rápidos -->
      <div class="md:col-span-3 lg:col-span-4 lg:justify-self-center">
        <h3 class="text-sm font-bold text-white tracking-wider uppercase mb-6">
          Enlaces Rápidos
        </h3>
        <ul class="space-y-4">
          <li>
            <a
              href="#servicios"
              class="text-slate-400 hover:text-blue-400 transition-colors"
              >Servicios</a
            >
          </li>
          <li>
            <a
              href="#nosotros"
              class="text-slate-400 hover:text-blue-400 transition-colors"
              >Sobre Nosotros</a
            >
          </li>
          <li>
            <a
              href="#contacto"
              class="text-slate-400 hover:text-blue-400 transition-colors"
              >Contacto</a
            >
          </li>
        </ul>
      </div>

      <!-- Columna 3: Contacto Directo -->
      <div class="md:col-span-4 lg:col-span-4 lg:justify-self-end">
        <h3 class="text-sm font-bold text-white tracking-wider uppercase mb-6">
          Contacto Directo
        </h3>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <svg
              class="w-5 h-5 text-slate-500 shrink-0 mt-0.5"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
            <a
              href="mailto:cristian.alegre.it@gmail.com"
              class="text-slate-400 hover:text-blue-400 transition-colors break-all"
              >cristian.alegre.it@gmail.com</a
            >
          </li>
          <li class="flex items-start gap-3">
            <svg
              class="w-5 h-5 text-slate-500 shrink-0 mt-0.5"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.243-4.243a8 8 0 1111.314 0z"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <span class="text-slate-400"
              >Santa Fe, Argentina <br /><span class="text-sm text-slate-500"
                >(Atención a clientes globales)</span
              >
            </span>
          </li>
          <li class="flex items-start gap-3">
            <svg
              class="w-5 h-5 text-slate-500 shrink-0 mt-0.5"
              xmlns="http://www.w3.org/2000/svg"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
              ></path>
            </svg>
            <a
              href="https://www.linkedin.com/in/cristian-nahuel-alegre-bustos/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-slate-400 hover:text-blue-400 transition-colors"
              >LinkedIn</a
            >
          </li>
        </ul>
      </div>
    </div>

    <!-- Barra Inferior (Legal) -->
    <div
      class="border-t border-slate-800/80 pt-8 flex flex-col items-center justify-center"
    >
      <p class="text-sm text-slate-500 text-center">
        &copy; 2026 Alegre Engineering Group. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>
