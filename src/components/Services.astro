---
// Services.astro
const services = [
  {
    title: "Desarrollo de Software y Web",
    description:
      "Creamos aplicaciones a medida, herramientas internas y arquitecturas robustas en la nube. Soluciones escalables y seguras de alto rendimiento, diseñadas para proteger tus datos y maximizar tu eficiencia operativa.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-600"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
  },
  {
    title: "Automatización e Integraciones",
    description:
      "Eliminamos tareas manuales conectando tus sistemas mediante APIs y scripts. Reducí costos operativos y erradicá el error humano. Libertad es que tus procesos sigan produciendo mientras vos estás fuera de la oficina disfrutando tu tiempo.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-600"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>`,
  },
  {
    title: "Soporte IT y Gestión de Equipos",
    description:
      "Dormí tranquilo. Actuamos como tu departamento técnico externo: mesa de ayuda, gestión de accesos y ciberseguridad. Resolvemos imprevistos a deshoras para que recuperes tu capacidad de enfoque estratégico y elimines el estrés técnico.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-600"><path d="M3 11h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-5Zm0 0a9 9 0 1 1 18 0m0 0v5a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3Z"/><path d="M21 16v2a4 4 0 0 1-4 4h-5"/></svg>`,
  },
  {
    title: "Inteligencia Artificial y Datos",
    description:
      "Implementamos IA basada en necesidades de negocio, optimizando el consumo de tokens para asegurar eficiencia de costos. Desde asistentes inteligentes hasta estructuración de datos para extraer métricas clave que aumenten tus ganancias.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-600"><path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/><path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"/><path d="M17.599 6.5a3 3 0 0 0 .399-1.375"/><path d="M6.003 5.125A3 3 0 0 0 6.401 6.5"/><path d="M3.477 10.896a4 4 0 0 1 .585-.396"/><path d="M19.938 10.5a4 4 0 0 1 .585.396"/><path d="M6 18a4 4 0 0 1-1.967-.516"/><path d="M19.967 17.484A4 4 0 0 1 18 18"/></svg>`,
  },
];
---

<section id="servicios" class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2
        class="text-3xl md:text-4xl font-extrabold text-blue-950 tracking-tight mb-4"
      >
        Nuestras Soluciones
      </h2>
      <div class="h-14 sm:h-8 flex items-center justify-center text-center">
        <p id="dynamic-subtitle" class="text-lg text-slate-600 transition-opacity duration-500 opacity-100">
          Cuidamos tu tiempo.
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-10">
      {
        services.map((service) => (
          <div class="group relative bg-white border border-slate-200 p-8 rounded-2xl shadow-sm hover:shadow-xl hover:border-blue-100 transition-all duration-300">
            <div class="absolute inset-0 bg-gradient-to-br from-blue-50/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity rounded-2xl" />
            <div class="relative z-10">
              <div
                class="w-14 h-14 rounded-xl bg-blue-50 border border-blue-100 flex items-center justify-center mb-6 group-hover:scale-110 group-hover:bg-blue-100 transition-all duration-300"
                set:html={service.icon}
              />
              <h3 class="text-xl font-bold text-slate-900 mb-3 group-hover:text-blue-900 transition-colors">
                {service.title}
              </h3>
              <p class="text-slate-600 leading-relaxed">
                {service.description}
              </p>
            </div>
          </div>
        ))
      }
    </div>
    <div
      class="mt-20 text-center italic text-slate-500 max-w-2xl mx-auto border-t border-slate-100 pt-8"
    >
      "En AEG, no medimos el éxito en líneas de código, sino en las horas que le
      devolvemos a nuestros clientes y en el crecimiento de su rentabilidad."
    </div>
  </div>
</section>

<script>
  const phrases = [
    "Cuidamos tu tiempo.",
    "Protegemos tu dinero.",
    "Potenciamos tu negocio.",
    "Aseguramos tu bienestar.",
    "Cubrimos todo el ciclo de vida tecnológico de tu empresa."
  ];

  const el = document.getElementById('dynamic-subtitle');
  if (el) {
    let currentIndex = 0;
    
    const changeText = () => {
      // Ocultar texto (fade out)
      el.classList.remove('opacity-100');
      el.classList.add('opacity-0');
      
      setTimeout(() => {
        // Actualizar texto y mostrar (fade in)
        currentIndex = (currentIndex + 1) % phrases.length;
        el.textContent = phrases[currentIndex];
        
        el.classList.remove('opacity-0');
        el.classList.add('opacity-100');
        
        // Mantener la última frase por 5 segundos en lugar de 3 antes de reiniciar el ciclo
        const nextDelay = currentIndex === phrases.length - 1 ? 5000 : 3000;
        setTimeout(changeText, nextDelay);
      }, 500); // 500ms para coincidir con el 'duration-500' de Tailwind
    };
    
    // Iniciar el ciclo después de 3 segundos
    setTimeout(changeText, 3000);
  }
</script>
